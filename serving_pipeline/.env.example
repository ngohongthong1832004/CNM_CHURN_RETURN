# MLflow — model alias set by churn_retraining_pipeline DAG
MODEL_URI=models:/customer_churn_model@champion
MLFLOW_TRACKING_URI=http://mlflow_server:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# MinIO / S3 credentials
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123
AWS_DEFAULT_REGION=us-east-1

# Feast online store — Redis runs in the Airflow stack (service name: redis)
FEAST_REDIS_CONNECTION_STRING=redis:6379

# Monitoring data paths (defaults match Docker container paths)
REFERENCE_DATA_PATH=/app/api/data/reference_data.csv
CURRENT_DATA_PATH=/app/api/data/production.csv

# UI → API
API_BASE_URL=http://api:8000
